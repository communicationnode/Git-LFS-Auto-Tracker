<ui:FluentWindow
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
        xmlns:local="clr-namespace:GitLFSAutoTracker"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" 
        x:Class="GitLFSAutoTracker.MainWindow"
        mc:Ignorable="d"
        Title="Auto LFS Tracker" MaxHeight="400" MaxWidth="320" MinHeight="400" MinWidth="320" ResizeMode="NoResize" Background="{x:Null}">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="0.1*"/>
            <RowDefinition Height="2*"/> <!-- 3 -->            
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="9*"/> <!-- 5 -->
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="0.3*"/>
        </Grid.RowDefinitions>

        <Image Source="/src/imgs/bg.png" Grid.RowSpan="9" Grid.ColumnSpan="9" Stretch="UniformToFill" Opacity="0.25"/>

        <Border x:Name="MainWindowBorder" Grid.ColumnSpan="3" Background="#FF383838">
            <Viewbox  HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,12,0">
                        <Label x:Name="Label_FilesCounter" Foreground="White" FontSize="22" Content="Finded files &gt; then 50mb" FontWeight="Bold" Cursor="Hand" Margin="4,0,4,0"/>
                    </Viewbox>
                    <ui:Button x:Name="Button_Close" HorizontalAlignment="Right">Close</ui:Button>
                </StackPanel>
            </Viewbox>
        </Border>
        
        <Viewbox Grid.Column="1" Grid.Row="3">
            <StackPanel x:Name="StackPanel_SizeButtons"  Orientation="Horizontal" HorizontalAlignment="Center" UseLayoutRounding="False" SnapsToDevicePixels="True" >
                <ui:Button x:Name="Button_Search25mb" Content="25 MB" Margin="4,0,4,0"/>
                <ui:Button x:Name="Button_Search49mb" Content="49 MB" Margin="4,0,4,0"/>
                <ui:Button x:Name="Button_Search99mb" Content="99 MB" Margin="4,0,4,0"/>
            </StackPanel>
        </Viewbox>

        <ui:ListView x:Name="ListBox_Files" Grid.Row="5" Grid.Column="1" Background="#FF525252"/>

        <ui:Button HorizontalAlignment="Stretch" x:Name="Button_CreateAttributes" Grid.Column="1" Content="Create .gitattributes" Grid.Row="7"/>
    </Grid>
</ui:FluentWindow>
