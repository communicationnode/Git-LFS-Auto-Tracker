<Window x:Class="GitLFSAutoTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="http://schemas.microsoft.com/netfx/2009/xaml/presentation"
        xmlns:local="clr-namespace:GitLFSAutoTracker"
        mc:Ignorable="d"
        Title="Auto LFS Tracker" MaxHeight="400" MaxWidth="320" MinHeight="400" MinWidth="320" ResizeMode="NoResize" Background="#FF3A3A3A">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="9*"/>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="0.3*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Viewbox Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Label x:Name="Label_FilesCounter" Foreground="White" FontSize="22" Content="Finded files &gt; then 50mb"/>
        </Viewbox>
        <ListBox x:Name="ListBox_Files" Grid.Row="3" Grid.Column="1" Background="#FF525252">

        </ListBox>
        <StackPanel x:Name="StackPanel_SizeButtons" Grid.Column="1" Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" UseLayoutRounding="False" SnapsToDevicePixels="True" >
            <Button x:Name="Button_Search25mb" Content="Search 25mb" Margin="4,0,4,0"/>
            <Button x:Name="Button_Search49mb" Content="Search 49mb" Margin="4,0,4,0"/>
            <Button x:Name="Button_Search99mb" Content="Search 99mb" Margin="4,0,4,0"/>
        </StackPanel>

        <Button x:Name="Button_CreateAttributes" Grid.Column="1" Content="Create .gitattributes" Grid.Row="7"/>
    </Grid>
</Window>
